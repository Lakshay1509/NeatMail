DODO_PRODUCT_ID_MAX_ANNUAL_GLOBAL=
# Extra-mailbox add-on — one product per interval × region, like the plan products
# above. A DodoPay add-on's billing cycle "must match your subscription's billing
# cycle", and an add-on bills ONCE PER CYCLE — so the annual products' price is a full
# YEAR of seat ($120 / ₹6000 at 12× monthly), not the monthly figure. Keep these in
# sync with MAILBOX_ADDON_PRICE in lib/tiers.ts or the billing page misquotes.
#   monthly: $10/mo GLOBAL, ₹500/mo INDIA
#   annual:  $120/yr GLOBAL, ₹6000/yr INDIA
#
# Comma-separated, NEWEST FIRST. Rotation must be ADDITIVE — prepend the new id and
# KEEP the retired one. DodoPay ids are immutable, so existing customers keep the id
# they bought; dropping it makes their cart unreadable, which suspends seat-cap
# enforcement for them rather than silently reading their seats as zero.
#   e.g. DODO_ADDON_MAILBOX_MONTHLY_GLOBAL=addon_new_id,addon_retired_id
# A multi-currency add-on (both USD + INR prices set) can fill both regions of an
# interval — set both to the same id. Never share an id across INTERVALS.
DODO_ADDON_MAILBOX_MONTHLY_INDIA=
DODO_ADDON_MAILBOX_MONTHLY_GLOBAL=
DODO_ADDON_MAILBOX_ANNUAL_INDIA=
DODO_ADDON_MAILBOX_ANNUAL_GLOBAL=
DODO_WEBHOOK_SECRET=
DODO_WEB_URL=
