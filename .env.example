NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# ID of the PostHog *popover* survey opened by the sidebar "Feedback" button.
# Create it under Surveys in the PostHog dashboard and paste its ID here.
NEXT_PUBLIC_POSTHOG_FEEDBACK_SURVEY_ID=

# Google OAuth verification test account — history sync is skipped for this email
# to avoid polluting the DB with the reviewer's test mailbox
GOOGLE_VERIFICATION_EMAIL=
