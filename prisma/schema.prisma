generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
  previewFeatures = ["multiSchema", "views"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

enum Tier {
  FREE
  PRO
  MAX

  @@schema("public")
}

enum PromiseStatus {
  PENDING
  NUDGED
  FULFILLED
  DISMISSED

  @@schema("public")
}

model user_tokens {
  clerk_user_id           String                 @id @unique
  email                   String                 @unique
  tier                    Tier                   @default(FREE)
  // True once the user has had a free premium trial, own or inherited via team.
  // Stays true after leaving/removal so they can't claim a new one. See checkout.ts.
  trial_used              Boolean                @default(false)
  created_at              DateTime               @default(now()) @db.Timestamp(6)
  updated_at              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  last_history_id         String?
  watch_activated         Boolean                @default(false)
  delete_at               DateTime?
  deleted_flag            Boolean                @default(false)
  is_gmail                Boolean                @default(true)
  outlook_id              String?
  is_folder               Boolean                @default(false)
  watched_folders         Json                   @default("[]")
  // First-run "Kaboom" sweep: stamped when the user runs the one-tap onboarding
  // inbox clear-out. Null = never swept, which is what gates the dashboard banner.
  // Count is the running total archived by the sweep (feeds the "quieter" metric).
  first_sweep_at          DateTime?
  first_sweep_count       Int                    @default(0)
  draft_preference        draft_preference?
  email_tracked           email_tracked[]
  payment_history         PaymentHistory[]
  refunds                 Refund[]
  subscriptions           Subscription[]
  tag                     tag[]
  user_tags               user_tags[]
  telegram_integration    TelegramIntegration?
  pending_drafts          telegramPendingDraft[]
  integration_rules       integrationRules[]
  free_trial              free_trial?
  archive_rules           ArchiveRule[]
  slack_integration       slack_integration?
  digest_preference       digest_preference?
  follow_up_preference    follow_up_preference?
  tracked_promises        tracked_promise[]
  chat_sessions           ChatSession[]
  referral_code           String?                @unique
  referral_months_granted Int                    @default(0)
  referrals_sent          Referral[]             @relation("ReferralsSent")
  referral_received       Referral?              @relation("ReferralReceived")
  organization_membership OrganizationMember?
  organization_created    Organization?

  @@schema("public")
}

model follow_up_preference {
  id                       String      @id @default(cuid())
  user_id                  String      @unique
  enabled                  Boolean     @default(false)
  ai_drafts                Boolean     @default(true)
  track_promises           Boolean     @default(false)
  days                     Int         @default(3)
  skip_emails              String      @default("")
  follow_up_count          Int         @default(0)
  follow_up_count_reset_at DateTime?
  user_tokens              user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model digest_preference {
  id            String      @id @default(cuid())
  user_id       String      @unique
  enabled       Boolean     @default(true)
  delivery_time String      @default("09:00")
  timezone      String      @default("UTC")
  last_sent_at  DateTime?
  user_tokens   user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model tag {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  color             String
  user_id           String?
  outlook_preset    String?
  description       String?
  email_tracked     email_tracked[]
  user_tokens       user_tokens?       @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)
  user_tags         user_tags[]
  integration_rules integrationRules[]
  archive_rules     ArchiveRule[]

  @@unique([name, user_id])
  @@schema("public")
}

model user_tags {
  user_id     String
  tag_id      String      @db.Uuid
  created_at  DateTime?   @default(now()) @db.Timestamptz(6)
  tag         tag         @relation(fields: [tag_id], references: [id], onDelete: Cascade, map: "user_tags_tag_fkey")
  user_tokens user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade, map: "user_tags_user_fkey")

  @@id([user_id, tag_id])
  @@index([tag_id], map: "idx_user_tags_tag_id")
  @@index([user_id], map: "idx_user_tags_user_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model email_tracked {
  user_id       String
  tag_id        String?     @db.Uuid
  message_id    String      @unique
  domain        String?
  is_read       Boolean     @default(false) @map("isRead")
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  archive_at    DateTime?   @db.Timestamptz(6)
  ai_summary    String?
  ai_action     String?
  isDone        Boolean     @default(false)
  snoozed_until DateTime?   @db.Timestamptz(6)
  tag           tag?        @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  user_tokens   user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@id([user_id, message_id])
  @@index([user_id], map: "idx_tracked_user")
  @@index([user_id, message_id], map: "idx_tracked_user_message")
  @@index([user_id, tag_id], map: "idx_tracked_user_tag")
  @@index([user_id, domain], map: "idx_tracked_user_domain")
  @@index([user_id, is_read, snoozed_until], map: "idx_tracked_user_read_snooze")
  @@schema("public")
}

/// Inbound "they owe me" promises extracted from received mail: a commitment the
/// SENDER made to deliver something by `due_at`. While PENDING and past due, the
/// sweep tags the Gmail thread ("Follow up" + INBOX + UNREAD) and drafts a nudge,
/// moving it to NUDGED. Flipped to FULFILLED when the promised thing lands in the
/// thread, or DISMISSED if the user strips the label themselves.
/// `item` and `from_email` are body-derived PII and are stored ENCRYPTED at
/// write-time, mirroring email_tracked.ai_summary (decrypt via lib helper on read).
model tracked_promise {
  id           String        @id @default(cuid())
  user_id      String
  thread_id    String
  message_id   String
  from_email   String
  from_domain  String?
  item         String
  due_at       DateTime      @db.Timestamptz(6)
  status       PromiseStatus @default(PENDING)
  confidence   Float?
  nudged_at    DateTime?     @db.Timestamptz(6)
  fulfilled_at DateTime?     @db.Timestamptz(6)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  user_tokens  user_tokens   @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@unique([user_id, message_id])
  @@index([status, due_at], map: "idx_promise_status_due")
  @@index([user_id, thread_id], map: "idx_promise_user_thread")
  @@schema("public")
}

model Subscription {
  id                       String           @id @default(uuid())
  clerkUserId              String           @map("clerk_user_id")
  dodoSubscriptionId       String           @unique @map("dodo_subscription_id")
  dodoCustomerId           String           @map("dodo_customer_id")
  customerEmail            String           @map("customer_email")
  customerName             String?          @map("customer_name")
  status                   String
  productId                String           @map("product_id")
  currency                 String           @default("USD")
  recurringAmount          Int              @map("recurring_amount")
  quantity                 Int              @default(1)
  // Paid extra-mailbox add-on seats beyond the tier's included allowance. Derived
  // from the DodoPay subscription's `addons` array on every webhook (source of truth).
  extraMailboxes           Int              @default(0) @map("extra_mailboxes")
  paymentFrequencyInterval String           @map("payment_frequency_interval")
  paymentFrequencyCount    Int              @map("payment_frequency_count")
  nextBillingDate          DateTime?        @map("next_billing_date")
  previousBillingDate      DateTime?        @map("previous_billing_date")
  cancelAtNextBillingDate  Boolean          @default(false) @map("cancel_at_next_billing_date")
  cancelledAt              DateTime?        @map("cancelled_at")
  reminder_sent_at         DateTime?        @db.Timestamptz(6)
  metadata                 Json?            @default("{}")
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  payments                 PaymentHistory[]
  user_tokens              user_tokens      @relation(fields: [clerkUserId], references: [clerk_user_id], onDelete: Cascade)

  @@index([clerkUserId])
  @@index([status])
  @@map("subscriptions")
  @@schema("public")
}

model PaymentHistory {
  id                 String        @id @default(uuid())
  clerkUserId        String        @map("clerk_user_id")
  subscriptionId     String?       @map("subscription_id")
  dodoPaymentId      String?       @unique @map("dodo_payment_id")
  dodoSubscriptionId String?       @map("dodo_subscription_id")
  amount             Int
  currency           String        @default("USD")
  status             String
  paymentType        String        @map("payment_type")
  billingDate        DateTime?     @map("billing_date")
  metadata           Json?         @default("{}")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  cardLastFour       String?       @map("card_last_four")
  cardNetwork        String?       @map("card_network")
  cardType           String?       @map("card_type")
  checkoutSessionId  String?       @map("checkout_session_id")
  errorCode          String?       @map("error_code")
  errorMessage       String?       @map("error_message")
  invoiceId          String?       @map("invoice_id")
  paymentMethod      String?       @map("payment_method")
  settlementAmount   Int?          @map("settlement_amount")
  user_tokens        user_tokens   @relation(fields: [clerkUserId], references: [clerk_user_id], onDelete: Cascade)
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id])
  refunds            Refund[]

  @@index([clerkUserId])
  @@index([subscriptionId])
  @@index([status])
  @@map("payment_history")
  @@schema("public")
}

model Refund {
  id            String         @id @default(uuid())
  clerkUserId   String         @map("clerk_user_id")
  dodoRefundId  String         @unique @map("dodo_refund_id")
  dodoPaymentId String         @map("dodo_payment_id")
  amount        Int
  currency      String         @default("USD")
  status        String
  reason        String?
  isPartial     Boolean        @map("is_partial")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  paymentId     String         @map("payment_id")
  user_tokens   user_tokens    @relation(fields: [clerkUserId], references: [clerk_user_id], onDelete: Cascade)
  payment       PaymentHistory @relation(fields: [paymentId], references: [id])

  @@index([clerkUserId])
  @@index([paymentId])
  @@index([status])
  @@map("refunds")
  @@schema("public")
}

model draft_preference {
  id                   String      @id @default(uuid())
  user_id              String      @unique
  draftPrompt          String?
  signature            String?
  fontSize             Int         @default(14) @db.SmallInt
  fontColor            String      @default("#000000")
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  enabled              Boolean     @default(true)
  timezone             String?
  senstivity           String?
  language             String      @default("english")
  draft_count          Int         @default(0)
  draft_count_reset_at DateTime?
  user_tokens          user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model TelegramIntegration {
  id                             String      @id @default(uuid())
  user_id                        String      @unique
  chat_id                        String      @unique
  forward_important_mails        Boolean     @default(false)
  forward_draft_for_confirmation Boolean     @default(false)
  user_tokens                    user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model slack_integration {
  id               String      @id @default(uuid())
  user_id          String      @unique
  access_token     String
  refresh_token    String?
  token_expires_at DateTime?
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  user_tokens      user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model telegramPendingDraft {
  id              String      @id @default(uuid())
  user_id         String
  telegram_msg_id Int
  draft_id        String
  quick_options   String[]
  awaiting_custom Boolean     @default(false)
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  user_tokens     user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

model integrationRules {
  id          String      @id @default(uuid())
  user_id     String
  domain      String
  tag_id      String      @db.Uuid
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  user_tokens user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)
  tag         tag         @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([user_id, domain], map: "idx_integration_rules_user_domain")
  @@index([user_id], map: "idx_integration_rules_user_id")
  @@index([tag_id], map: "idx_integration_rules_tag_id")
  @@index([domain], map: "idx_integration_rules_domain")
  @@map("integration_rules")
  @@schema("public")
}

enum trial_status {
  ACTIVE
  EXPIRED
  CONVERTED
  CHURNED

  @@schema("public")
}

model free_trial {
  id               String       @id @default(uuid())
  user_id          String       @unique
  email            String       @unique
  started_at       DateTime     @default(now()) @db.Timestamptz(6)
  expires_at       DateTime     @db.Timestamptz(6)
  status           trial_status @default(ACTIVE)
  converted_at     DateTime?    @db.Timestamptz(6)
  reminder_sent_at DateTime?    @db.Timestamptz(6)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user_tokens user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@schema("public")
}

enum ArchiveRuleSource {
  USER
  SEEDED
  // Created by the engagement scan (lib/engagement.ts) for senders the user
  // gets a lot of mail from but almost never opens. archiveAfterDays is 0: the
  // mail workers archive their mail on arrival, and the daily sweep clears the
  // backlog. When a user hits Undo, the row stays as a tombstone (isActive
  // false) instead of being deleted, so the scan never re-mutes them.
  AUTO

  @@schema("public")
}

// Fires on exactly one target, `domain` XOR `tag_id`, enforced by a CHECK
// constraint Prisma can't express. See the /archive-messages cron.
model ArchiveRule {
  id               String            @id @default(uuid())
  user_id          String
  domain           String?
  tag_id           String?           @db.Uuid
  archiveAfterDays Int
  isActive         Boolean           @default(true)

  // USER rules sweep the existing backlog; SEEDED (onboarding defaults) only
  // touch mail arriving after createdAt. Enforced in the /archive-messages cron.
  source           ArchiveRuleSource @default(USER)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user_tokens user_tokens @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)
  tag         tag?        @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([user_id, domain])
  @@unique([user_id, tag_id])
  @@index([isActive, user_id])
  @@index([isActive, tag_id])
  @@schema("public")
}

model ChatSession {
  id          String        @id @default(uuid())
  user_id     String
  title       String?
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user_tokens user_tokens   @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)
  messages    ChatMessage[]

  // covers the sidebar query (user_id + order by updated_at desc)
  @@index([user_id, updated_at(sort: Desc)])
  @@map("chat_sessions")
  @@schema("public")
}

model ChatMessage {
  id         String      @id @default(uuid())
  session_id String
  is_user    Boolean
  content    String
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  session    ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  // covers loading a thread in order + keyset pagination
  @@index([session_id, created_at])
  @@map("chat_messages")
  @@schema("public")
}

enum ReferralStatus {
  PENDING
  REWARDED
  CAPPED
  REVOKED

  @@schema("public")
}

model Referral {
  id                String         @id @default(uuid())
  referrer_user_id  String
  referee_user_id   String         @unique
  referral_code     String
  status            ReferralStatus @default(PENDING)
  reward_applied_at DateTime?
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @updatedAt @db.Timestamptz(6)

  referrer user_tokens @relation("ReferralsSent", fields: [referrer_user_id], references: [clerk_user_id], onDelete: Cascade)
  referee  user_tokens @relation("ReferralReceived", fields: [referee_user_id], references: [clerk_user_id], onDelete: Cascade)

  @@index([referrer_user_id])
  @@index([referral_code])
  @@map("referrals")
  @@schema("public")
}

enum OrganizationRole {
  MEMBER
  ADMIN

  @@schema("public")
}

model Organization {
  id         String               @id @default(uuid())
  name       String
  created_by String               @unique @map("created_by")
  created_at DateTime             @default(now()) @db.Timestamptz(6)
  updated_at DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator    user_tokens          @relation(fields: [created_by], references: [clerk_user_id], onDelete: Cascade)
  members    OrganizationMember[]
  invites    OrganizationInvite[]

  @@map("organization")
  @@schema("public")
}

model OrganizationInvite {
  id              String           @id @default(uuid())
  token           String           @unique
  organization_id String           @map("organization_id")
  email           String?
  role            OrganizationRole @default(MEMBER)
  invited_by      String           @map("invited_by")
  expires_at      DateTime         @db.Timestamptz(6)
  used_at         DateTime?        @db.Timestamptz(6)
  used_by         String?          @map("used_by")
  created_at      DateTime         @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("organization_invites")
  @@schema("public")
}

model OrganizationMember {
  id              String           @id @default(uuid())
  user_id         String           @unique
  organization_id String           @map("organization_id")
  role            OrganizationRole @default(MEMBER)
  // Owner can pause a teammate's mailbox processing without removing them; a
  // paused member keeps their seat but their Gmail watch is stopped.
  active          Boolean          @default(true)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization    Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user_tokens     user_tokens      @relation(fields: [user_id], references: [clerk_user_id], onDelete: Cascade)

  @@index([organization_id])
  @@index([organization_id, role])
  @@map("organization_members")
  @@schema("public")
}
